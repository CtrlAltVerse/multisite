{
   "$schema": "https://schemas.wp.org/trunk/theme.json",
   "version": 3,
   "settings": {
      "layout": {
         "contentSize": "56rem",
         "wideSize": "96rem"
      },
      "spacing": {
         "units": ["px", "em", "rem", "%"]
      },
      "typography": {
         "lineHeight": true,
         "customFontSize": true,
         "fontSizes": [
            {
               "name": "Small",
               "slug": "small",
               "size": "0.8125em"
            },
            {
               "name": "Medium",
               "slug": "medium",
               "size": "1.25em"
            },
            {
               "name": "Large",
               "slug": "large",
               "size": "2.25em"
            },
            {
               "name": "Extra Large",
               "slug": "x-large",
               "size": "2.625em"
            }
         ],
         "fontFamilies": [
            {
               "fontFamily": "'Myriad Pro', Seravek, Ember, 'Trebuchet MS', 'BN Trebuchet MS', 'PT Sans', 'Frutiger Neue', Roboto, sans-serif;",
               "name": "Humanist",
               "slug": "humanist"
            },
            {
               "fontFamily": "Futura, 'Century Gothic', 'Apple SD Gothic Neo', AppleGothic, sans-serif;",
               "name": "Geometric",
               "slug": "geometric"
            },
            {
               "fontFamily": "Athelas, Literata, Bookerly, 'Merriweather Serif', Malabar, 'BN Malabar', Georgia, 'Droid Serif', serif;",
               "name": "Modern",
               "slug": "modern"
            }
         ]
      },
      "color": {
         "palette": [
            {
               "name": "Black Sky",
               "slug": "black-sky",
               "color": "#131314"
            },
            {
               "name": "Dark Graffiti",
               "slug": "dark-graffiti",
               "color": "#262629"
            },
            {
               "name": "Graffiti",
               "slug": "graffiti",
               "color": "#5e5e66"
            },
            {
               "name": "Dark Gray",
               "slug": "dark-gray",
               "color": "#a9ab8"
            },
            {
               "name": "Gray",
               "slug": "gray",
               "color": "#ddddf9"
            }
         ]
      }
   },
   "styles": {
      "color": {
         "text": "#f8f8f2",
         "background": "#282a36"
      },
      "typography": {
         "fontSize": "120%",
         "lineHeight": "1.5"
      },
      "spacing": { "blockGap": "1.5em" },
      "blocks": {
         "core/quote": {
            "spacing": {
               "margin": {
                  "top": "1.5em",
                  "bottom": "1.5em",
                  "left": "5%",
                  "right": "5%"
               }
            },
            "typography": {
               "fontStyle": "italic"
            }
         },
         "core/image": {
            "spacing": {
               "margin": {
                  "top": "0",
                  "bottom": "0"
               }
            }
         },
         "core/figure": {
            "spacing": {
               "margin": {
                  "top": "0",
                  "bottom": "0"
               }
            }
         },
         "core/separator": {
            "spacing": {
               "margin": {
                  "top": "1.4375em",
                  "bottom": "1.4375em",
                  "right": "0",
                  "left": "37.5%"
               }
            }
         }
      },
      "elements": {
         "h1": {
            "typography": {
               "fontSize": "1.4375em",
               "lineHeight": "1.04347826"
            },
            "spacing": {
               "margin": {
                  "top": "0",
                  "bottom": "2.08695652em"
               }
            }
         },
         "h2": {
            "typography": {
               "fontSize": "1.3125em",
               "lineHeight": "1.14285714"
            },
            "spacing": {
               "margin": {
                  "top": "2.28571429em",
                  "bottom": "1.14285714em"
               }
            }
         },
         "h3": {
            "typography": {
               "fontSize": "1.125em",
               "lineHeight": "1.33333333"
            },
            "spacing": {
               "margin": {
                  "top": "1.33333333em",
                  "bottom": "1.33333333em"
               }
            }
         },
         "h4": {
            "typography": {
               "fontSize": "1em",
               "lineHeight": "1.5"
            },
            "spacing": {
               "margin": {
                  "top": "1.5em",
                  "bottom": "1.5em"
               }
            }
         },
         "h5": {
            "typography": {
               "textIndent": "1em",
               "fontWeight": "600"
            }
         },
         "h6": {
            "typography": {
               "textIndent": "1em",
               "fontWeight": "600"
            }
         }
      }
   }
}
