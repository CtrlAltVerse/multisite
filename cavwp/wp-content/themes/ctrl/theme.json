{
   "$schema": "https://schemas.wp.org/trunk/theme.json",
   "version": 3,
   "settings": {
      "layout": {
         "contentSize": "56rem",
         "wideSize": "96rem"
      },
      "spacing": {
         "units": ["px", "em", "rem", "%"]
      },
      "typography": {
         "customFontSize": false,
         "dropCap": false,
         "fontStyle": false,
         "fontWeight": false,
         "letterSpacing": false,
         "lineHeight": false,
         "textColumns": false,
         "textDecoration": false,
         "textTransform": false,
         "writingMode": false,
         "fontFamilies": [
            {
               "fontFamily": "'Source Serif 4', Cardo,'Minion Pro','Iowan Old Style',Palatino,'Palatino Linotype','Palatino Nova','BN Amasis',Cambria,FreeSerif,'Times New Roman',serif",
               "name": "Transitional",
               "slug": "transitional"
            },
            {
               "fontFamily": "'Inria Serif',Athelas, Literata, Bookerly, 'Merriweather Serif', Malabar, 'BN Malabar', Georgia, 'Droid Serif', serif;",
               "name": "Modern",
               "slug": "modern"
            },
            {
               "fontFamily": "Inter,'Helvetica Neue',Helvetica,Arial,Roboto,'Noto Sans',sans-serif",
               "name": "Neo Grotesque",
               "slug": "neo-grotesque"
            },
            {
               "fontFamily": "Lato,'Myriad Pro', Seravek, Ember, 'Trebuchet MS', 'BN Trebuchet MS', 'PT Sans', 'Frutiger Neue', Roboto, sans-serif;",
               "name": "Humanist",
               "slug": "humanist"
            },
            {
               "fontFamily": "Jost,Futura, 'Century Gothic', 'Apple SD Gothic Neo', AppleGothic, sans-serif;",
               "name": "Geometric",
               "slug": "geometric"
            }
         ]
      },
      "color": {
         "palette": [
            {
               "name": "Black Sky",
               "slug": "black-sky",
               "color": "#131314"
            },
            {
               "name": "Dark Graffiti",
               "slug": "dark-graffiti",
               "color": "#262629"
            },
            {
               "name": "Graffiti",
               "slug": "graffiti",
               "color": "#5e5e66"
            },
            {
               "name": "Dark Gray",
               "slug": "dark-gray",
               "color": "#a9ab8"
            },
            {
               "name": "Gray",
               "slug": "gray",
               "color": "#ddddf9"
            }
         ]
      }
   },
   "styles": {
      "color": {
         "text": "#f8f8f2",
         "background": "#282a36"
      },
      "typography": {
         "fontSize": "1rem",
         "lineHeight": "1.5"
      },
      "spacing": { "blockGap": "1.5em" },
      "blocks": {
         "core/quote": {
            "spacing": {
               "margin": {
                  "top": "1.5em",
                  "bottom": "1.5em",
                  "left": "0",
                  "right": "0"
               }
            },
            "typography": {
               "fontStyle": "italic"
            }
         },
         "core/image": {
            "spacing": {
               "margin": {
                  "top": "0",
                  "bottom": "0"
               }
            }
         },
         "core/figure": {
            "spacing": {
               "margin": {
                  "top": "1rem",
                  "bottom": "1rem"
               }
            }
         },
         "core/separator": {
            "dimensions": { "height": "1rem", "width": "100%" },
            "border": { "style": "none" },
            "color": { "text": "#777" },
            "spacing": {
               "margin": {
                  "top": "1.5rem",
                  "bottom": "1.5rem",
                  "right": "auto",
                  "left": "auto"
               }
            },
            "variations": {
               "wide": {
                  "dimensions": { "width": "40%!important" },
                  "border": {
                     "width": "0 0 0.25rem 0",
                     "style": "solid"
                  }
               }
            }
         }
      },
      "elements": {
         "h1": {
            "typography": {
               "fontSize": "2.5rem",
               "lineHeight": "1.35"
            },
            "spacing": {
               "margin": {
                  "top": "0",
                  "bottom": "8rem"
               }
            }
         },
         "h2": {
            "typography": {
               "fontSize": "1.8rem",
               "lineHeight": "1.35"
            },
            "spacing": {
               "margin": {
                  "top": "2rem",
                  "bottom": "1rem"
               }
            }
         },
         "h3": {
            "typography": {
               "fontSize": "1.4rem",
               "lineHeight": "1.35"
            },
            "spacing": {
               "margin": {
                  "top": "1.8rem",
                  "bottom": "1rem"
               }
            }
         },
         "h4": {
            "typography": {
               "fontSize": "1.1rem",
               "lineHeight": "1.5"
            },
            "spacing": {
               "margin": {
                  "top": "1.5rem",
                  "bottom": "1rem"
               }
            }
         },
         "h5": {
            "typography": {
               "fontSize": "1rem",
               "lineHeight": "1.5",
               "textIndent": "1rem",
               "fontWeight": "600"
            },
            "spacing": {
               "margin": {
                  "top": "1rem",
                  "bottom": "0"
               }
            }
         },
         "h6": {
            "typography": {
               "fontSize": "1rem",
               "lineHeight": "1.5",
               "textIndent": "1rem",
               "fontWeight": "600"
            },
            "spacing": {
               "margin": {
                  "top": "1rem",
                  "bottom": "0"
               }
            }
         }
      }
   }
}
