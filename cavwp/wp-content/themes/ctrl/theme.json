{
   "$schema": "https://schemas.wp.org/trunk/theme.json",
   "version": 3,
   "settings": {
      "layout": {
         "contentSize": "16cm",
         "wideSize": "1280px",
         "allowEditing": false
      },
      "spacing": {
         "blockGap": true,
         "units": ["px", "em", "rem", "%"]
      },
      "dimensions": {
         "defaultAspectRatios": false
      },
      "typography": {
         "customFontSize": false,
         "defaultFontSizes": false,
         "dropCap": true,
         "fontStyle": false,
         "fontWeight": false,
         "letterSpacing": false,
         "lineHeight": true,
         "textColumns": false,
         "textDecoration": false,
         "textTransform": true,
         "writingMode": false,
         "fontFamilies": [
            {
               "fontFamily": "'Source Serif 4', Cardo,'Minion Pro','Iowan Old Style',Palatino,'Palatino Linotype','Palatino Nova','BN Amasis',Cambria,FreeSerif,'Times New Roman',serif",
               "name": "Transitional",
               "slug": "transitional"
            },
            {
               "fontFamily": "'Inria Serif',Athelas, Literata, Bookerly, 'Merriweather Serif', Malabar, 'BN Malabar', Georgia, 'Droid Serif', serif;",
               "name": "Modern",
               "slug": "modern"
            },
            {
               "fontFamily": "'Inter','Helvetica Neue',Helvetica,Arial,Roboto,'Noto Sans',sans-serif",
               "name": "Neo Grotesque",
               "slug": "neo-grotesque"
            },
            {
               "fontFamily": "'Lato','Myriad Pro', Seravek, Ember, 'Trebuchet MS', 'BN Trebuchet MS', 'PT Sans', 'Frutiger Neue', Roboto, sans-serif;",
               "name": "Humanist",
               "slug": "humanist"
            },
            {
               "fontFamily": "'Jost',Futura, 'Century Gothic', 'Apple SD Gothic Neo', AppleGothic, sans-serif;",
               "name": "Geometric",
               "slug": "geometric"
            },
            {
               "fontFamily": "'JetBrains Mono', Menlo, Monaco, Consolas, 'Courier New', monospace",
               "name": "Monospace",
               "slug": "monospace"
            }
         ],
         "fontSizes": [
            { "name": "Pequena", "slug": "small", "size": "0.84rem" },
            { "name": "Médio", "slug": "medium", "size": "1.4rem" },
            { "name": "Grande", "slug": "large", "size": "1.8rem" },
            { "name": "Maior", "slug": "x-large", "size": "2.5rem" }
         ]
      },
      "color": {
         "palette": [
            {
               "name": "Black Sky",
               "slug": "black-sky",
               "color": "#131314"
            },
            {
               "name": "Dark Graffiti",
               "slug": "dark-graffiti",
               "color": "#262629"
            },
            {
               "name": "Graffiti",
               "slug": "graffiti",
               "color": "#5e5e66"
            },
            {
               "name": "Dark Gray",
               "slug": "dark-gray",
               "color": "#a9a9b8"
            },
            {
               "name": "Gray",
               "slug": "gray",
               "color": "#ddddf9"
            }
         ]
      },
      "blocks": {
         "core/pullquote": {
            "border": { "width": false, "radius": false }
         }
      }
   },
   "styles": {
      "color": {
         "text": "#f8f8f2",
         "background": "#282a36"
      },
      "typography": {
         "fontSize": "1rem",
         "lineHeight": "1.5",
         "fontFamily": "'Merriweather', 'Merriweather Serif', 'Times New Roman', serif"
      },
      "spacing": { "blockGap": "0.25rem" },
      "blocks": {
         "core/paragraph": {
            "variations": {
               "no-indent": {
                  "css": "text-indent:0;"
               },
               "hanging": {
                  "spacing": {
                     "padding": {
                        "left": "calc(var(--wp--style--block-gap) * 5)"
                     }
                  },
                  "css": "text-indent:calc(var(--wp--style--block-gap) * -5);"
               }
            }
         },
         "core/pullquote": {
            "typography": {
               "textIndent": "0",
               "fontStyle": "italic",
               "fontSize": "calc(var(--wp--style--block-gap) * 5))"
            },
            "spacing": { "margin": { "left": "auto", "right": "auto" } },
            "css": "&{width: 90%} &.has-text-align-center{max-width: 650px}",
            "elements": {
               "cite": {
                  "typography": {
                     "fontStyle": "normal"
                  },
                  "spacing": {
                     "margin": {
                        "top": "calc(var(--wp--style--block-gap) * 3)"
                     }
                  },
                  "css": "display:block"
               }
            }
         },
         "core/quote": {
            "spacing": {
               "margin": {
                  "top": "calc(var(--wp--style--block-gap) * 4)",
                  "bottom": "calc(var(--wp--style--block-gap) * 4)",
                  "left": "calc(var(--wp--style--block-gap) * 6)",
                  "right": "calc(var(--wp--style--block-gap) * 6)"
               },
               "padding": {
                  "top": "calc(var(--wp--style--block-gap) * 2)",
                  "bottom": "calc(var(--wp--style--block-gap) * 2)",
                  "left": "calc(var(--wp--style--block-gap) * 4)"
               }
            },
            "border": {
               "top": {
                  "width": "0"
               },
               "right": {
                  "width": "0"
               },
               "bottom": {
                  "width": "0"
               },
               "left": {
                  "width": "var(--wp--style--block-gap)",
                  "style": "solid",
                  "color": "currentColor"
               }
            },
            "typography": {
               "textIndent": "0",
               "fontStyle": "italic"
            },
            "css": "& em{font-style: normal}",
            "elements": {
               "cite": {
                  "typography": { "fontStyle": "normal" },
                  "spacing": {
                     "margin": { "top": "var(--wp--style--block-gap)" }
                  },
                  "css": "display:block"
               },
               "heading": {
                  "typography": {
                     "fontSize": "1em",
                     "lineHeight": "inherit",
                     "fontWeight": "bold",
                     "fontStyle": "normal"
                  },
                  "spacing": {
                     "margin": { "top": "0", "bottom": "0" }
                  }
               }
            },
            "variations": {
               "digital": {
                  "typography": {
                     "fontFamily": "var(--wp--preset--font-family--monospace)",
                     "fontStyle": "normal"
                  },
                  "color": {
                     "text": "#000",
                     "gradient": ""
                  },
                  "background": {
                     "backgroundImage": "linear-gradient(90deg, rgb(234, 234, 234) 0%, rgb(255, 255, 255) 50%)"
                  },
                  "border": {
                     "left": {
                        "color": "var(--wp--preset--color--graffiti)"
                     }
                  },
                  "spacing": {
                     "margin": {
                        "top": "calc(var(--wp--style--block-gap) * 2)",
                        "bottom": "calc(var(--wp--style--block-gap) * 2)",
                        "left": "0",
                        "right": "0"
                     },
                     "padding": {
                        "left": "calc(var(--wp--style--block-gap) * 6)"
                     }
                  }
               }
            }
         },
         "core/verse": {
            "spacing": {
               "margin": {
                  "top": "calc(var(--wp--style--block-gap) * 4)",
                  "bottom": "calc(var(--wp--style--block-gap) * 4)",
                  "left": "0",
                  "right": "0"
               }
            }
         },
         "core/code": {
            "typography": {
               "fontFamily": "var(--wp--preset--font-family--monospace)",
               "fontSize": "1rem"
            },
            "spacing": {
               "margin": {
                  "top": "calc(var(--wp--style--block-gap) * 4)",
                  "bottom": "calc(var(--wp--style--block-gap) * 4)"
               },
               "padding": {
                  "top": "calc(var(--wp--style--block-gap) * 2.5)",
                  "bottom": "calc(var(--wp--style--block-gap) * 2.5)",
                  "right": "calc(var(--wp--style--block-gap) * 3)",
                  "left": "calc(var(--wp--style--block-gap) * 3)"
               }
            },
            "border": {
               "width": "var(--wp--style--block-gap)",
               "style": "solid",
               "color": "currentColor"
            }
         },
         "core/image": {
            "dimensions": { "height": "auto", "width": "auto" },
            "border": { "style": "none" },
            "spacing": {
               "margin": {
                  "top": "calc(var(--wp--style--block-gap) * 4)",
                  "bottom": "calc(var(--wp--style--block-gap) * 4)"
               }
            },
            "elements": {
               "link": { "typography": { "textDecoration": "none" } },
               "caption": {
                  "typography": {
                     "fontSize": "var(--wp--preset--font-size--small)",
                     "textAlign": "center",
                     "fontWeight": "bold"
                  }
               }
            }
         },
         "core/separator": {
            "dimensions": {
               "minHeight": "calc(var(--wp--style--block-gap) * 4)",
               "width": "40%"
            },
            "border": { "style": "none" },
            "color": { "text": "#777" },
            "background": { "backgroundImage": "none" },
            "spacing": {
               "margin": {
                  "top": "calc(var(--wp--style--block-gap) * 6)",
                  "bottom": "calc(var(--wp--style--block-gap) * 6)",
                  "right": "auto",
                  "left": "auto"
               },
               "padding": {
                  "bottom": "0",
                  "top": "0",
                  "right": "0",
                  "left": "0"
               }
            },
            "variations": {
               "wide": {
                  "border": {
                     "bottom": {
                        "width": "var(--wp--style--block-gap)",
                        "style": "solid"
                     }
                  },
                  "css": "opacity: 0.5;"
               },
               "asterism": {
                  "color": { "background": "transparent" },
                  "spacing": {
                     "margin": {
                        "top": "calc(var(--wp--style--block-gap) * 4)",
                        "bottom": "calc(var(--wp--style--block-gap) * 4)"
                     }
                  },
                  "dimensions": {
                     "minHeight": "calc(var(--wp--style--block-gap) * 8)"
                  },
                  "background": {
                     "backgroundRepeat": "no-repeat",
                     "backgroundPosition": "center",
                     "backgroundImage": "url('https://cdn.altvers.net/sites/3/2026/02/asterism.png')"
                  },
                  "css": "opacity: 0.8;"
               }
            }
         },
         "core/list": {
            "spacing": {
               "margin": {
                  "top": "calc(var(--wp--style--block-gap) * 4)",
                  "bottom": "calc(var(--wp--style--block-gap) * 4)"
               }
            },
            "css": "& ol,ul{padding-left:calc(var(--wp--style--block-gap) * 4);margin: 0}",
            "variations": {
               "square": {
                  "css": "list-style-type:square;"
               },
               "default": {
                  "css": "list-style-type:inherit"
               },
               "circle": {
                  "css": "list-style-type:circle;"
               },
               "none": {
                  "spacing": { "padding": { "left": "0" } },
                  "css": "list-style-type:none"
               },
               "horizontal": {
                  "css": "display:flex; gap:calc(var(--wp--style--block-gap) * 4); list-style-type:none;"
               }
            }
         },
         "core/table": {
            "spacing": {
               "margin": {
                  "top": "calc(var(--wp--style--block-gap) * 4)",
                  "bottom": "calc(var(--wp--style--block-gap) * 4)",
                  "left": "auto",
                  "right": "auto"
               }
            },
            "elements": {
               "caption": {
                  "typography": {
                     "fontSize": "var(--wp--preset--font-size--small)",
                     "textAlign": "center",
                     "fontWeight": "bold"
                  }
               }
            },
            "variations": {
               "filecard": {
                  "typography": {
                     "fontFamily": "var(--wp--preset--font-family--monospace)",
                     "fontSize": "var(--wp--preset--font-size--small)"
                  },
                  "spacing": {
                     "margin": {
                        "top": "calc(var(--wp--style--block-gap) * 6)",
                        "bottom": "calc(var(--wp--style--block-gap) * 6)",
                        "left": "auto",
                        "right": "auto"
                     }
                  },
                  "border": {
                     "style": "solid",
                     "color": "currentColor",
                     "top": {
                        "width": "calc(var(--wp--style--block-gap) * 0.5)"
                     },
                     "bottom": {
                        "width": "calc(var(--wp--style--block-gap) * 0.5)"
                     },
                     "left": {
                        "width": "0"
                     },
                     "right": {
                        "width": "0"
                     }
                  },
                  "css": "& td,tr,thead,tfoot{border:none};&{max-width: 12.5cm}"
               },
               "borderless": {
                  "css": "& td,tr,thead,tfoot{border:none}"
               }
            }
         },
         "cav/dt": {
            "typography": { "fontWeight": "bold" },
            "spacing": {
               "margin": { "top": "calc(var(--wp--style--block-gap) * 2)" }
            }
         },
         "cav/dd": {
            "spacing": {
               "margin": { "bottom": "calc(var(--wp--style--block-gap) * 4)" }
            }
         }
      },
      "elements": {
         "h1": {
            "typography": {
               "fontSize": "calc(var(--wp--style--block-gap) * 10)",
               "lineHeight": "1.35"
            },
            "spacing": {
               "margin": {
                  "top": "0",
                  "bottom": "calc(var(--wp--style--block-gap) * 24)"
               }
            }
         },
         "h2": {
            "typography": {
               "fontSize": "calc(var(--wp--style--block-gap) * 7)",
               "lineHeight": "1.35"
            },
            "spacing": {
               "margin": {
                  "top": "calc(var(--wp--style--block-gap) * 8)",
                  "bottom": "calc(var(--wp--style--block-gap) * 4)"
               }
            }
         },
         "h3": {
            "typography": {
               "fontSize": "calc(var(--wp--style--block-gap) * 6)",
               "lineHeight": "1.35"
            },
            "spacing": {
               "margin": {
                  "top": "calc(var(--wp--style--block-gap) * 8)",
                  "bottom": "calc(var(--wp--style--block-gap) * 4)"
               }
            }
         },
         "h4": {
            "typography": {
               "fontSize": "calc(var(--wp--style--block-gap) * 5)",
               "lineHeight": "1.5"
            },
            "spacing": {
               "margin": {
                  "top": "calc(var(--wp--style--block-gap) * 6)",
                  "bottom": "calc(var(--wp--style--block-gap) * 4)"
               }
            }
         },
         "h5": {
            "typography": {
               "fontSize": "calc(var(--wp--style--block-gap) * 4)",
               "lineHeight": "1.5",
               "textIndent": "calc(var(--wp--style--block-gap) * 4)",
               "fontWeight": "bold"
            },
            "spacing": {
               "margin": {
                  "top": "calc(var(--wp--style--block-gap) * 4)",
                  "bottom": "0"
               }
            }
         },
         "h6": {
            "typography": {
               "fontSize": "calc(var(--wp--style--block-gap) * 4)",
               "lineHeight": "1.5",
               "textIndent": "calc(var(--wp--style--block-gap) * 4)",
               "fontWeight": "bold"
            },
            "spacing": {
               "margin": {
                  "top": "calc(var(--wp--style--block-gap) * 4)",
                  "bottom": "0"
               }
            }
         }
      },
      "css": ".small-caps{font-variant-caps: small-caps;}pre{font-family:inherit}ul{list-style-position: inside}"
   }
}
